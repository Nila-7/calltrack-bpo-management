rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * INTELLISYNCEX SECURITY POSTURE:
     * 1. Path-based isolation for user document workspaces.
     * 2. Identity-mapped global audit trails (activity_logs).
     * 3. Role-based administrative override.
     * 4. Support for public username lookups for registration/login mapping.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    match /users/{userId} {
      // Allow get for any signed in user to load their own or others' basic profiles
      allow get: if isSignedIn();
      // Allow anyone to check for a username (limit 1) to support "Login by Username" and "Unique Username" checks.
      allow list: if isAdmin() || (request.query.limit == 1);
      // Allow self-registration: user must be signed in (via Firebase Auth) and creating their own document.
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Owners and Admins can update profiles.
      allow update: if isOwner(userId) || isAdmin();
      // Only Admins can delete users.
      allow delete: if isAdmin();
    }

    match /users/{userId}/documents/{documentId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId) || isAdmin();

      match /entity_detections/{detectionId} {
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /activity_logs/{activityLogId} {
      // Admins see all logs. Users see their own identity-mapped logs.
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if false; // Audit integrity
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}