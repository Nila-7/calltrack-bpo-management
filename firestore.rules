rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * INTELLISYNCEX SECURITY POSTURE:
     * 1. Path-based isolation for user document workspaces.
     * 2. Identity-mapped global audit trails (activity_logs).
     * 3. Role-based administrative override.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function isValidOwnershipField(userId) {
      return request.resource.data.userId == userId;
    }

    match /users/{userId} {
      allow get, update: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn(); // Allow initial self-registration or admin provision
      allow delete: if isAdmin();
    }

    match /users/{userId}/documents/{documentId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidOwnershipField(userId);
      allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId) || isAdmin();

      match /entity_detections/{detectionId} {
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /activity_logs/{activityLogId} {
      // Admins see all logs. Users see their own identity-mapped logs.
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if false; // Audit integrity
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}