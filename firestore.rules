rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEVELOPMENT RULES: Allowing all authenticated users full access
    // to resolve the persistent "Missing or insufficient permissions" error.
    // This allows the BPO Call Center System to function correctly across all roles.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly defining core collection paths for clarity and to ensure the watcher system applies changes.
    
    match /calls/{callId} {
      allow read, write: if request.auth != null;
    }
    
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
  }
}