rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissive development rules for all authenticated users.
    // This ensures that agents and admins can access 'calls', 'userProfiles', and 'activity_logs'
    // without permission barriers while the system is in development.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}