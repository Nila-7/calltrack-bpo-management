rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Development mode: Explicitly allow all read and write operations for any authenticated user.
    // This ensures that the 'calls', 'userProfiles', and 'activity_logs' collections are accessible 
    // to agents and admins without permission errors during the development phase.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}