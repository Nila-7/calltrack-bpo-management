rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Development mode: Allow all read and write operations for any authenticated user across all collections.
    // This is a robust rule to ensure the BPO Call Center System can operate without permission barriers.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}