rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow authenticated users to read and write to the core BPO collections.
    // This provides a permissive environment for development and ensures no list/get operations are blocked.
    
    match /calls/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /userProfiles/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Fallback for any other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}